# Atlas local development environment

ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# Database
ATLAS_MYSQL_HOST=localhost
ATLAS_MYSQL_PORT=3306
ATLAS_MYSQL_DATABASE=atlas_global
ATLAS_MYSQL_USER=root
ATLAS_MYSQL_PASSWORD=root

# Redis
ATLAS_REDIS_CONNECTION=localhost:6379,abortConnect=false,allowAdmin=true

# RabbitMQ
ATLAS_RABBITMQ_HOST=localhost
ATLAS_RABBITMQ_PORT=5672
ATLAS_RABBITMQ_VIRTUAL_HOST=/
ATLAS_RABBITMQ_USERNAME=guest
ATLAS_RABBITMQ_PASSWORD=guest

# Security placeholders for local development only.
ATLAS_CRYPTO_KEY=replace-with-at-least-32-characters
ATLAS_TOKEN_SECRET=replace-with-a-long-random-token-secret

# Snowflake
SNOWFLAKE_WORKER_ID=1
SNOWFLAKE_DATACENTER_ID=1

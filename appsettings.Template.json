{
  "ConnectionStrings": {
    "AtlasGlobal": "Server=${ATLAS_MYSQL_HOST};Port=${ATLAS_MYSQL_PORT};Database=${ATLAS_MYSQL_DATABASE};User=${ATLAS_MYSQL_USER};Password=${ATLAS_MYSQL_PASSWORD};CharSet=utf8mb4;AllowPublicKeyRetrieval=true;"
  },
  "Atlas": {
    "Runtime": {
      "Mode": "WebApi",
      "EnableMessagingConsumers": false,
      "EnableTenantOutboxDispatcher": false,
      "EnableBackgroundJobWorker": false,
      "EnableRecurringTaskRunner": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Atlas": {
      "EnableConsole": true,
      "EnableFile": true,
      "EnableSeq": false,
      "SeqServerUrl": "",
      "SeqApiKey": null,
      "FilePath": "logs/application/atlas-.log",
      "ErrorFilePath": "logs/application/atlas-errors-.log",
      "AuditFilePath": "logs/audit/audit-.log",
      "MinimumLevel": "Information",
      "EnableSensitiveDataFilter": true,
      "SensitiveFields": [
        "password",
        "pwd",
        "secret",
        "token",
        "accessToken",
        "refreshToken",
        "apikey",
        "phone",
        "mobile",
        "email"
      ],
      "LogRequestBody": false,
      "LogResponseBody": false,
      "SlowOperationThresholdMs": 500
    }
  },
  "Security": {
    "Crypto": {
      "Key": "${ATLAS_CRYPTO_KEY}"
    },
    "Token": {
      "SecretKey": "${ATLAS_TOKEN_SECRET}",
      "ExpirationMinutes": 1440,
      "RefreshTokenExpirationDays": 7,
      "CookieName": "atlas-auth-token",
      "EnableQueryStringToken": false,
      "EnableCustomHeader": true
    },
    "TestTokens": {
      "Enabled": false
    },
    "LoginPath": "/login"
  },
  "CacheSettings": {
    "Provider": "Memory",
    "Redis": {
      "ConnectionString": "${ATLAS_REDIS_CONNECTION}",
      "InstanceName": "atlas"
    },
    "Hybrid": {
      "RedisConnectionString": "${ATLAS_REDIS_CONNECTION}",
      "L1ExpirationMinutes": 5
    }
  },
  "Messaging": {
    "Provider": "None",
    "RabbitMQ": {
      "Host": "${ATLAS_RABBITMQ_HOST}",
      "Port": 5672,
      "VirtualHost": "${ATLAS_RABBITMQ_VIRTUAL_HOST}",
      "Username": "${ATLAS_RABBITMQ_USERNAME}",
      "Password": "${ATLAS_RABBITMQ_PASSWORD}",
      "PrefetchCount": 16,
      "RetryLimit": 5,
      "RetryIntervalSeconds": 5
    },
    "TenantOutbox": {
      "Enabled": false,
      "PollIntervalSeconds": 5,
      "TenantBatchSize": 100,
      "MessageBatchSize": 50,
      "MaxAttempts": 10,
      "InitialRetryDelaySeconds": 10,
      "MaxRetryDelaySeconds": 300,
      "ProcessingTimeoutSeconds": 300
    }
  },
  "BackgroundTasks": {
    "Recurring": {
      "Enabled": false,
      "PollIntervalSeconds": 10,
      "LockSeconds": 300
    },
    "OneTimeJobs": {
      "Enabled": false,
      "Queues": [ "default", "tenant" ],
      "PollIntervalSeconds": 5,
      "BatchSize": 20,
      "ProcessingTimeoutSeconds": 300,
      "InitialRetryDelaySeconds": 10,
      "MaxRetryDelaySeconds": 300,
      "DefaultMaxAttempts": 5
    },
    "TenantOutboxMaintenance": {
      "Enabled": false,
      "IntervalMinutes": 60,
      "RetentionDays": 30,
      "TenantBatchSize": 100,
      "DeleteBatchSize": 500,
      "RunOnStartup": false
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "ServiceName": "Atlas",
      "Exporter": "None",
      "OtlpEndpoint": "http://localhost:4317",
      "OtlpProtocol": "Grpc",
      "InstrumentRuntime": true
    }
  },
  "Snowflake": {
    "WorkerId": 1,
    "DatacenterId": 1
  },
  "AllowedHosts": "*"
}

{
  "Security": {
    "TestTokens": {
      "Enabled": true
    }
  },
  "CacheSettings": {
    "Provider": "Memory"
  },
  "Messaging": {
    "Provider": "None"
  },
  "BackgroundTasks": {
    "Recurring": {
      "Enabled": false
    },
    "OneTimeJobs": {
      "Enabled": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}

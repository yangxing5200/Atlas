{
  "Atlas": {
    "Http": {
      "Clients": {
        "PaymentX": {
          "BaseUrl": "https://api.paymentx.example",
          "TimeoutSeconds": 5,
          "Logging": {
            "SensitiveHeaders": [
              "X-Access-Key",
              "X-Signature"
            ]
          },
          "Resilience": {
            "Retry": {
              "Enabled": true,
              "MaxAttempts": 2,
              "BaseDelayMilliseconds": 200,
              "MaxDelayMilliseconds": 1000,
              "StatusCodes": [ 408, 429, 500, 502, 503, 504 ]
            },
            "CircuitBreaker": {
              "Enabled": true,
              "FailureThreshold": 5,
              "BreakSeconds": 30
            },
            "RateLimit": {
              "Enabled": true,
              "PermitLimit": 100,
              "WindowSeconds": 1
            }
          }
        }
      }
    }
  },
  "Integrations": {
    "PaymentX": {
      "ApiPrefix": "/api/v1",
      "MerchantId": "",
      "AccessKey": "",
      "SecretKey": ""
    }
  }
}

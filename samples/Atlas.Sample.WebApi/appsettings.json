{
    "ConnectionStrings": {
        "AtlasGlobal": "Server=localhost;Port=3306;Database=atlas_global;User=root;Password=root;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;",
        "MySqlTest": "Server=localhost;Port=3306;Database=atlas_test;User=root;Password=root;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;",
        "MySqlTestDocker": "Server=localhost;Port=3306;Database=atlas_test;User=root;Password=root;CharSet=utf8mb4;"
    },
    "Atlas": {
        "Runtime": {
            "Mode": "WebApi"
        }
    },

    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information"
        },
        "Atlas": {
            "EnableConsole": true,
            "EnableFile": true,
            "EnableSeq": false,
            "FilePath": "logs/application/atlas-.log",
            "ErrorFilePath": "logs/application/atlas-errors-.log",
            "AuditFilePath": "logs/audit/audit-.log",
            "RetainedFileCount": 7,
            "ErrorRetainedFileCount": 30,
            "AuditRetainedFileCount": 365,
            "SeqServerUrl": "",
            "SeqApiKey": null,
            "MinimumLevel": "Debug",
            "EnableSensitiveDataFilter": true,
            "SensitiveFields": [
                "password",
                "pwd",
                "secret",
                "token",
                "apikey",
                "idcard",
                "idnumber",
                "phone",
                "mobile",
                "email",
                "bankcard",
                "creditcard",
                "accessToken",
                "refreshToken"
            ],
            "LogRequestBody": true,
            "LogResponseBody": false,
            "SlowOperationThresholdMs": 500
        }
    },

    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
        "MinimumLevel": {
            "Default": "Debug",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.EntityFrameworkCore": "Information",
                "Microsoft.EntityFrameworkCore.Database.Command": "Information",
                "System": "Warning"
            }
        },
        "WriteTo": [
            {
                "Name": "Async",
                "Args": {
                    "configure": [
                        {
                            "Name": "Console",
                            "Args": {
                                "theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console",
                                "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
                            }
                        }
                    ]
                }
            }
        ],
        "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId", "WithProcessId" ]
    },

    "Security": {
        "Crypto": {
            "Key": "your-super-secret-encryption-key-at-least-32-chars-long!!!"
        },
        "Token": {
            "SecretKey": "your-super-secret-token-signing-key-should-be-very-long-and-random",
            "ExpirationMinutes": 1440,
            "RefreshTokenExpirationDays": 7,
            "CookieName": "atlas-auth-token"
        },
        "TestTokens": {
            "Enabled": false
        },
        "LoginPath": "/login"
    },
    "TestSettings": {
        "UseMySql": true,
        "UseInMemory": false,
        "LargeBatchSize": 10000,
        "SmallBatchSize": 100
    },
    "CacheSettings": {
        "Provider": "Redis",
        "Redis": {
            "ConnectionString": "localhost:6379,abortConnect=false,allowAdmin=true",
            "InstanceName": "atlas-test"
        },
        "Hybrid": {
            "RedisConnectionString": "localhost:6379,abortConnect=false,allowAdmin=true",
            "L1ExpirationMinutes": 5,
            "L1MaxItems": 1000
        }
    },
    "Messaging": {
        "Provider": "RabbitMQ",
        "RabbitMQ": {
            "Host": "localhost",
            "Port": 5672,
            "VirtualHost": "/",
            "Username": "guest",
            "Password": "guest",
            "PrefetchCount": 16,
            "RetryLimit": 5,
            "RetryIntervalSeconds": 5
        },
        "TenantOutbox": {
            "Enabled": false,
            "PollIntervalSeconds": 5,
            "TenantBatchSize": 100,
            "MessageBatchSize": 50,
            "MaxAttempts": 10,
            "InitialRetryDelaySeconds": 10,
            "MaxRetryDelaySeconds": 300,
            "ProcessingTimeoutSeconds": 300
        }
    },
    "BackgroundTasks": {
        "Recurring": {
            "Enabled": false,
            "PollIntervalSeconds": 10,
            "LockSeconds": 300
        },
        "OneTimeJobs": {
            "Enabled": false,
            "Queues": [ "default", "tenant" ],
            "PollIntervalSeconds": 5,
            "BatchSize": 20,
            "ProcessingTimeoutSeconds": 300,
            "InitialRetryDelaySeconds": 10,
            "MaxRetryDelaySeconds": 300,
            "DefaultMaxAttempts": 5
        },
        "TenantOutboxMaintenance": {
            "Enabled": true,
            "IntervalMinutes": 60,
            "RetentionDays": 30,
            "TenantBatchSize": 100,
            "DeleteBatchSize": 500,
            "RunOnStartup": false
        }
    },
    "Observability": {
        "OpenTelemetry": {
            "Enabled": false,
            "ServiceName": "Atlas.Sample.WebApi",
            "Exporter": "None",
            "OtlpEndpoint": "http://localhost:4317",
            "OtlpProtocol": "Grpc",
            "InstrumentRuntime": true
        }
    },
    "Snowflake": {
        "WorkerId": 1,
        "DatacenterId": 1
    }
}

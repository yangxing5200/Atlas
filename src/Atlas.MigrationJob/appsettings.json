{
  "ConnectionStrings": {
    "AtlasGlobal": "Server=localhost;Port=3306;Database=atlas_global;User=root;Password=root;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;"
  },
  "Atlas": {
    "Runtime": {
      "Mode": "Migration"
    }
  },
  "CacheSettings": {
    "Provider": "Memory"
  },
  "Messaging": {
    "Provider": "None"
  },
  "BackgroundTasks": {
    "Recurring": {
      "Enabled": false
    },
    "OneTimeJobs": {
      "Enabled": false,
      "Queues": [ "default" ]
    },
    "TenantOutboxMaintenance": {
      "Enabled": false
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "ServiceName": "Atlas.MigrationJob",
      "Exporter": "None",
      "OtlpEndpoint": "http://localhost:4317",
      "OtlpProtocol": "Grpc",
      "InstrumentRuntime": false
    }
  },
  "Snowflake": {
    "WorkerId": 1,
    "DatacenterId": 1
  }
}

{
  "ConnectionStrings": {
    "AtlasGlobal": "Server=localhost;Port=3306;Database=atlas_global;User=root;Password=root;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;"
  },
  "Atlas": {
    "Runtime": {
      "Mode": "WebApi"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Atlas": {
      "EnableConsole": true,
      "EnableFile": true,
      "EnableSeq": false,
      "FilePath": "logs/application/atlas-.log",
      "ErrorFilePath": "logs/application/atlas-errors-.log",
      "AuditFilePath": "logs/audit/audit-.log",
      "MinimumLevel": "Information",
      "EnableSensitiveDataFilter": true,
      "SensitiveFields": [
        "password",
        "pwd",
        "secret",
        "token",
        "accessToken",
        "refreshToken",
        "apikey",
        "phone",
        "mobile",
        "email"
      ],
      "LogRequestBody": false,
      "LogResponseBody": false,
      "SlowOperationThresholdMs": 500
    }
  },
  "Security": {
    "Crypto": {
      "Key": "your-super-secret-encryption-key-at-least-32-chars-long"
    },
    "Token": {
      "SecretKey": "your-super-secret-token-signing-key-should-be-very-long",
      "ExpirationMinutes": 1440,
      "RefreshTokenExpirationDays": 7,
      "CookieName": "atlas-auth-token",
      "EnableQueryStringToken": false
    },
    "TestTokens": {
      "Enabled": false
    },
    "LoginPath": "/login"
  },
  "CacheSettings": {
    "Provider": "Memory"
  },
  "Messaging": {
    "Provider": "None",
    "TenantOutbox": {
      "Enabled": false
    }
  },
  "BackgroundTasks": {
    "Recurring": {
      "Enabled": false
    },
    "OneTimeJobs": {
      "Enabled": false,
      "Queues": [ "default", "tenant" ]
    },
    "TenantOutboxMaintenance": {
      "Enabled": false
    }
  },
  "Exporting": {
    "Enabled": true,
    "DefaultFormat": "csv",
    "AllowedFormats": [ "csv" ],
    "DefaultPageSize": 500,
    "MaxPageSize": 2000,
    "DefaultMaxRows": 100000,
    "RetentionDays": 7,
    "StorageProvider": "Local",
    "LocalStorage": {
      "RootPath": "var/exports"
    },
    "Cleanup": {
      "Enabled": false,
      "IntervalMinutes": 60,
      "BatchSize": 100
    }
  },
  "Observability": {
    "OpenTelemetry": {
      "Enabled": false,
      "ServiceName": "Atlas.WebApi",
      "Exporter": "None",
      "OtlpEndpoint": "http://localhost:4317",
      "OtlpProtocol": "Grpc",
      "InstrumentRuntime": true
    }
  },
  "Snowflake": {
    "WorkerId": 1,
    "DatacenterId": 1
  },
  "AllowedHosts": "*"
}

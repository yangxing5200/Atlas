{
  "ConnectionStrings": {
    "AtlasGlobal": "Server=localhost;Port=3306;Database=atlas_global_bidops;User=root;Password=root;CharSet=utf8mb4;AllowPublicKeyRetrieval=true;"
  },
  "CacheSettings": {
    "Provider": "Memory"
  },
  "Messaging": {
    "Provider": "None",
    "TenantOutbox": {
      "Enabled": false
    }
  },
  "BackgroundTasks": {
    "Recurring": {
      "Enabled": true,
      "PollIntervalSeconds": 10,
      "LockSeconds": 300
    },
    "OneTimeJobs": {
      "Enabled": true,
      "Queues": [ "default", "tenant", "export", "bidops" ],
      "MaxConcurrency": 8,
      "JobTypeConcurrency": {
        "bidops.ai.structured-parse": 3,
        "bidops.outcome.supplier-extract": 3,
        "bidops.crawl.state-grid-ecp-scan": 1
      },
      "MaxRunningSeconds": 7200
    },
    "TenantOutboxMaintenance": {
      "Enabled": false
    }
  },
  "BidOps": {
    "FileStore": {
      "LocalRootPath": "var/bidops-storage",
      "FallbackLocalRootPaths": [
        "src/Atlas.Worker/var/bidops-storage",
        "src/Atlas.Worker/bin/Debug/net8.0/storage/bidops"
      ]
    },
    "ScheduledScan": {
      "Enabled": true,
      "IntervalMinutes": 5,
      "RunOnStartup": true,
      "MaxChannelsPerCycle": 4,
      "IncrementalMaxPages": 1,
      "BackfillMaxPagesPerCycle": 3,
      "TenantIds": [ 300001 ],
      "UserId": 300001,
      "UserName": "BidOps Scheduler"
    },
    "Recovery": {
      "Enabled": true,
      "IntervalMinutes": 2,
      "RunOnStartup": true,
      "MaxRawPerCycle": 50,
      "TenantIds": [ 300001 ],
      "UserId": 300001,
      "UserName": "BidOps Recovery"
    },
    "OpportunityMaintenance": {
      "Enabled": false,
      "IntervalMinutes": 10,
      "RunOnStartup": false,
      "MaxItemsPerJob": 100,
      "DeadlineWarningDays": 7,
      "StaleDays": 14,
      "TenantIds": [ 300001 ],
      "UserId": 300001,
      "UserName": "BidOps Opportunity Maintenance"
    },
    "SupplierMaintenance": {
      "Enabled": false,
      "IntervalMinutes": 30,
      "RunOnStartup": false,
      "MaxItemsPerJob": 100,
      "EvidenceWarningDays": 30,
      "TenantIds": [ 300001 ],
      "UserId": 300001,
      "UserName": "BidOps Supplier Maintenance"
    },
    "StateGridEcp": {
      "MaxNoticesPerScan": 20
    },
    "Attachments": {
      "MaxAttachmentBytes": 31457280
    },
    "Ai": {
      "Enabled": true,
      "Provider": "CodexCli",
      "BaseUrl": "https://api.deepseek.com",
      "Endpoint": "",
      "Model": "deepseek-v4-pro",
      "MaxInputCharacters": 24000,
      "UseForNoticeStaging": true,
      "UseForOutcomeSuppliers": true
    },
    "Mimo": {
      "BaseUrl": "https://token-plan-cn.xiaomimimo.com/v1",
      "Endpoint": "",
      "Model": "mimo-v2.5-pro",
      "MinRequestIntervalSeconds": 15,
      "RateLimitBackoffSeconds": 180,
      "ApiKey": ""
    },
    "CodexCli": {
      "BinaryPath": "codex.cmd",
      "Model": "gpt-5.5",
      "ReasoningEffort": "low",
      "WorkingDirectory": "",
      "TimeoutSeconds": 600,
      "Sandbox": "read-only",
      "SkipGitRepoCheck": true,
      "IgnoreUserConfig": false,
      "IgnoreRules": true,
      "Ephemeral": true,
      "ApiKey": ""
    }
  }
}
